{
  "name": "yuanbao-lite",
  "version": "11.3.1",
  "type": "module",
  "description": "Lightweight standalone Yuanbao bot client — chat, commands, media, stickers, LLM takeover, interactive CLI",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "yb-cli": "./dist/cli/index.js",
    "yuanbao-lite-cli": "./dist/cli/index.js"
  },
  "files": [
    "src",
    "dist",
    "tsconfig.json",
    "README.md"
  ],
  "keywords": [
    "yuanbao",
    "tencent-im",
    "chatbot",
    "standalone",
    "sticker",
    "media-upload",
    "llm",
    "ai-takeover",
    "cli"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "cli": "node dist/cli/index.js",
    "daemon": "node dist/cli/index.js daemon start",
    "daemon:start": "node dist/cli/index.js daemon start",
    "daemon:stop": "node dist/cli/index.js daemon stop",
    "daemon:status": "node dist/cli/index.js daemon status",
    "daemon:restart": "node dist/cli/index.js daemon restart",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.117",
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/provider": "^3.0.10",
    "@clack/prompts": "^1.5.1",
    "ai": "^6.0.206",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "defuddle": "^0.19.0",
    "linkedom": "^0.18.12",
    "marked": "^18.0.5",
    "protobufjs": "^7.5.4",
    "string-width": "^8.2.1",
    "table": "^6.9.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1"
  }
}
