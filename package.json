{
  "name": "yuanbao-lite-monorepo",
  "private": true,
  "version": "12.0.0",
  "type": "module",
  "description": "Yuanbao Lite monorepo — core library + CLI",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build --workspace @yuanbao-lite/core",
    "build:cli": "npm run build --workspace @yuanbao-lite/cli",
    "lint": "eslint packages/",
    "test": "npm run test --workspace @yuanbao-lite/core",
    "test:e2e": "npm run test:e2e --workspace @yuanbao-lite/core"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1"
  }
}
