{
  "name": "yuanbao-lite",
  "private": false,
  "version": "12.8.2",
  "type": "module",
  "description": "Yuanbao Lite monorepo — core library + CLI",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core; tsc -b packages/cli",
    "build:core": "tsc -b packages/core",
    "build:cli": "tsc -b packages/cli",
    "start": "node packages/cli/dist/index.js",
    "cli": "node packages/cli/dist/index.js",
    "daemon": "node packages/cli/dist/index.js daemon start",
    "daemon:start": "node packages/cli/dist/index.js daemon start",
    "daemon:stop": "node packages/cli/dist/index.js daemon stop",
    "daemon:status": "node packages/cli/dist/index.js daemon status",
    "daemon:restart": "node packages/cli/dist/index.js daemon restart",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "test": "pnpm run test packages/core",
    "test:e2e": "pnpm run test:e2e packages/core"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1"
  }
}
